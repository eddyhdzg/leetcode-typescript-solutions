// AI-free practice: edit predictions OFF, LSP completions + Biome format-on-save ON.
{
  "edit_predictions": { "provider": "none", "disabled_globs": ["**"] },
  "show_edit_predictions": false,

  "format_on_save": "on",

  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": false
      }
    }
  },

  "languages": {
    "TypeScript": {
      "show_edit_predictions": false,
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "show_edit_predictions": false,
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JavaScript": {
      "show_edit_predictions": false,
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
      }
    },
    "JSX": {
      "show_edit_predictions": false,
      "formatter": { "language_server": { "name": "biome" } }
    },
    "JSON": { "formatter": { "language_server": { "name": "biome" } } },
    "JSONC": { "formatter": { "language_server": { "name": "biome" } } }
  }
}
